{
  "name": "sidequest-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=../.env.local --experimental-strip-types src/main.ts dev",
    "start": "node --env-file-if-exists=../.env.local --experimental-strip-types src/main.ts start",
    "test": "node --test \"test/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@livekit/agents": "1.5.0",
    "@livekit/rtc-node": "^0.13.31",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
