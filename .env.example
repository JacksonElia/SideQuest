# Copy to .env.local and fill in. NEVER commit real values — this repo is public.
# All values come from https://cloud.livekit.io -> your project -> Settings.

# Project WebSocket URL, e.g. wss://your-project.livekit.cloud
LIVEKIT_URL=

# API key ID (starts with "API").
LIVEKIT_API_KEY=

# API secret — the HMAC signing key, shown ONCE when the key is created.
# If you no longer have it, generate a new key/secret pair.
LIVEKIT_API_SECRET=

# The agent's name as registered in the LiveKit Cloud dashboard.
# Explicit dispatch targets this exact string.
LIVEKIT_AGENT_NAME=

# Dashboard agent ID (e.g. CA_xxx). Not used by the dispatch API — kept for
# reference / dashboard cross-checking only.
LIVEKIT_AGENT_ID=

# Local token server port. Optional, defaults to 3001.
PORT=3001

# --- OpenRouter (out-of-band LLM work: summarization, agent prep) -------------
# Only needed for the LLM layer. The token server boots fine without it.

# API key from https://openrouter.ai/keys — shown only once when created.
OPENROUTER_API_KEY=

# Optional. Single default model for all out-of-band work.
# Defaults to anthropic/claude-haiku-4.5 when unset.
OPENROUTER_MODEL=

# Optional tuning. Defaults: 60000ms timeout, 4 concurrent requests per batch.
OPENROUTER_TIMEOUT_MS=
OPENROUTER_CONCURRENCY=

# Optional attribution for OpenRouter's public app rankings. Not secret.
OPENROUTER_APP_TITLE=
OPENROUTER_HTTP_REFERER=
