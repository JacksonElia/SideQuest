# Copy to .env.local and fill in. NEVER commit real values — this repo is public.
# --- Moss (semantic retrieval; the only datastore) ---------------------------
# From the Moss dashboard. Required only with STORE_BACKEND=moss.

MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=

# Optional. Which Store backend to build: "moss" or "fake" (the default).
# Vercel's Linux runtime cannot load the current Moss native binding, so Vercel
# deployments must use "fake" until Moss publishes a compatible binary.
STORE_BACKEND=

# Optional. Where Moss caches the downloaded index and its embedding model.
# Defaults to .moss-cache locally and /tmp/moss-cache on Vercel, which is the
# only writable location there.
MOSS_MODEL_CACHE_DIR=

# --- Bright Data (SERP ingestion: scripts/ingest-sf.ts) -----------------------
# API key from https://brightdata.com -> Account settings -> API tokens.
# Required by `npm run ingest:sf`; everything else runs without it.

BRIGHTDATA_API_KEY=

# Optional. SERP API zone name. Defaults to serp_api1.
BRIGHTDATA_SERP_ZONE=

# --- OpenRouter (out-of-band LLM work: summarization, agent prep) -------------
# Only needed for the LLM layer. The token server boots fine without it.

# API key from https://openrouter.ai/keys — shown only once when created.
OPENROUTER_API_KEY=

# Optional. Single default model for all out-of-band work.
# Defaults to anthropic/claude-haiku-4.5 when unset.
OPENROUTER_MODEL=

# Optional tuning. Defaults: 60000ms timeout, 4 concurrent requests per batch.
OPENROUTER_TIMEOUT_MS=
OPENROUTER_CONCURRENCY=

# Optional attribution for OpenRouter's public app rankings. Not secret.
OPENROUTER_APP_TITLE=
OPENROUTER_HTTP_REFERER=
