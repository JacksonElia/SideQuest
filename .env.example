# Copy to .env.local and fill in. NEVER commit real values — this repo is public.
# All values come from https://cloud.livekit.io -> your project -> Settings.

# Project WebSocket URL, e.g. wss://your-project.livekit.cloud
LIVEKIT_URL=

# API key ID (starts with "API").
LIVEKIT_API_KEY=

# API secret — the HMAC signing key, shown ONCE when the key is created.
# If you no longer have it, generate a new key/secret pair.
LIVEKIT_API_SECRET=

# The agent's name. Both sides of the wire use this exact string: the web app
# dispatches by it (lib/server/livekit.ts) and the worker in agent/ registers
# under it. If a dashboard-hosted agent shares the name it will compete for the
# same jobs — disable it while running the local worker.
LIVEKIT_AGENT_NAME=

# Dashboard agent ID (e.g. CA_xxx). Not used by the dispatch API — kept for
# reference / dashboard cross-checking only.
LIVEKIT_AGENT_ID=

# --- Voice agent worker (agent/) ---------------------------------------------

# Where the worker reaches the Next app to run Moss lookups via POST /api/query.
# Defaults to http://localhost:3000. In production this must be the deployed
# origin — the worker does not run inside Next.
SIDEQUEST_API_URL=

# Optional. Cartesia voice id for the guide. Unset uses the model's default
# voice; pick one that suits a gentle older gentleman.
SIDEQUEST_TTS_VOICE=

# --- Moss (semantic retrieval; the only datastore) ---------------------------
# From the Moss dashboard. Required by the query path and both index workers.

MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=

# Optional. Which Store backend to build: "moss" (default) or "fake".
# "fake" is the in-memory double used by tests — never point a demo at it.
STORE_BACKEND=

# Optional. Where Moss caches the downloaded index and its embedding model.
# Defaults to .moss-cache locally and /tmp/moss-cache on Vercel, which is the
# only writable location there.
MOSS_MODEL_CACHE_DIR=

# --- OpenRouter (out-of-band LLM work: summarization, agent prep) -------------
# Only needed for the LLM layer. The token server boots fine without it.

# API key from https://openrouter.ai/keys — shown only once when created.
OPENROUTER_API_KEY=

# Optional. Single default model for all out-of-band work.
# Defaults to anthropic/claude-haiku-4.5 when unset.
OPENROUTER_MODEL=

# Optional tuning. Defaults: 60000ms timeout, 4 concurrent requests per batch.
OPENROUTER_TIMEOUT_MS=
OPENROUTER_CONCURRENCY=

# Optional attribution for OpenRouter's public app rankings. Not secret.
OPENROUTER_APP_TITLE=
OPENROUTER_HTTP_REFERER=
