{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    // Server modules import each other with explicit .ts extensions so the same
    // files run unbundled under `node --test`, which has no extension guessing.
    // The bundler resolves the exact path fine, so both paths agree.
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", ".next/types/**/*.ts", "**/*.ts", "**/*.tsx"],
  // agent/ is a separate package with its own tsconfig: it targets NodeNext and
  // uses Node-only globals, so type-checking it under the bundler settings here
  // would report errors that its own `npm run typecheck` correctly accepts.
  "exclude": ["node_modules", "agent"]
}
