{
  "name": "sidequest",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "node --env-file-if-exists=.env.local --test \"test/*.test.ts\"",
    "agent:install": "npm --prefix agent install",
    "agent:dev": "npm --prefix agent run dev",
    "agent:start": "npm --prefix agent run start",
    "agent:test": "npm --prefix agent test",
    "bootstrap": "node --env-file=.env.local scripts/bootstrap.ts",
    "fixtures": "node --env-file=.env.local scripts/run-fixtures.ts",
    "smoke": "node --env-file=.env.local scripts/smoke.ts",
    "llm:smoke": "node --env-file=.env.local scripts/llm-smoke.ts",
    "moss:smoke": "node --env-file=.env.local scripts/moss-smoke.ts"
  },
  "dependencies": {
    "@inferedge/moss": "^1.0.0-beta.8",
    "@moss-dev/moss": "^1.4.0",
    "@openrouter/sdk": "0.13.43",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.12",
    "livekit-client": "^2.20.1",
    "livekit-server-sdk": "2.17.0",
    "lucide-react": "^0.468.0",
    "next": "^15.4.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.4.6",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
